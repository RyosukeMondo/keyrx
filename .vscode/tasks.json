{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Verify Dart Bindings",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/verify_dart_bindings.py"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Build Rust Core",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "-p",
        "keyrx_core",
        "--lib"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "Verify Dart Bindings"
      ],
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "Generate Dart Bindings",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/generate_dart_bindings.py"
      ],
      "problemMatcher": []
    }
  ]
}
