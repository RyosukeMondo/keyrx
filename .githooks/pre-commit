#!/usr/bin/env bash
#
# Pre-commit hook: enforces code quality before commits
# Runs: cargo fmt --check, cargo clippy, cargo test --lib
#

set -e

# Find repository root by looking for .git directory
find_repo_root() {
    local dir="$1"
    while [[ "$dir" != "/" ]]; do
        if [[ -d "$dir/.git" ]]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(find_repo_root "$SCRIPT_DIR")"

if [[ -z "$REPO_ROOT" ]]; then
    echo "Error: Could not find repository root" >&2
    exit 1
fi

CORE_DIR="$REPO_ROOT/core"

# Change to core directory for cargo commands
cd "$CORE_DIR"

echo ""
echo "╔════════════════════════════════════════════════════════════╗"
echo "║                   Pre-commit Checks                        ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""

TOTAL_CHECKS=4
PASSED_CHECKS=0

# Step 1: Format check
echo "[1/$TOTAL_CHECKS] Checking code formatting..."
if ! cargo fmt --check 2>/dev/null; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  ❌ FAILED: Code formatting check                          ║"
    echo "╠════════════════════════════════════════════════════════════╣"
    echo "║  Your code has formatting issues.                          ║"
    echo "║                                                            ║"
    echo "║  To fix, run:                                              ║"
    echo "║    cd core && cargo fmt                                    ║"
    echo "║                                                            ║"
    echo "║  Or use just:                                              ║"
    echo "║    just fmt                                                ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    exit 1
fi
PASSED_CHECKS=$((PASSED_CHECKS + 1))
echo "    ✓ Formatting OK"
echo ""

# Step 2: Clippy lint check
echo "[2/$TOTAL_CHECKS] Running clippy lints..."
if ! cargo clippy --quiet -- -D warnings 2>&1; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  ❌ FAILED: Clippy lint check                              ║"
    echo "╠════════════════════════════════════════════════════════════╣"
    echo "║  Clippy found warnings that must be fixed.                 ║"
    echo "║                                                            ║"
    echo "║  Review the warnings above and fix them, or use:           ║"
    echo "║    just clippy                                             ║"
    echo "║                                                            ║"
    echo "║  For specific fixes, check clippy documentation:           ║"
    echo "║    https://rust-lang.github.io/rust-clippy/                ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    exit 1
fi
PASSED_CHECKS=$((PASSED_CHECKS + 1))
echo "    ✓ Clippy OK"
echo ""

# Step 3: Unit tests (lib only for speed)
echo "[3/$TOTAL_CHECKS] Running unit tests..."
if ! cargo test --lib --quiet 2>&1; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  ❌ FAILED: Unit tests                                     ║"
    echo "╠════════════════════════════════════════════════════════════╣"
    echo "║  Some tests are failing.                                   ║"
    echo "║                                                            ║"
    echo "║  To run tests with output:                                 ║"
    echo "║    cd core && cargo test --lib                             ║"
    echo "║                                                            ║"
    echo "║  Or use just:                                              ║"
    echo "║    just test                                               ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    exit 1
fi
PASSED_CHECKS=$((PASSED_CHECKS + 1))
echo "    ✓ Tests OK"
echo ""

# Step 4: Verify FFI bindings
echo "[4/$TOTAL_CHECKS] Verifying FFI bindings..."
if ! python3 "$REPO_ROOT/scripts/verify_bindings.py"; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  ❌ FAILED: FFI Bindings Verification                      ║"
    echo "╠════════════════════════════════════════════════════════════╣"
    echo "║  Dart FFI bindings are out of sync with Rust exports.      ║"
    echo "║                                                            ║"
    echo "║  To fix, run:                                              ║"
    echo "║    just gen-bindings                                       ║"
    echo "║                                                            ║"
    echo "║  Then add the updated files to your commit.                ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    exit 1
fi
PASSED_CHECKS=$((PASSED_CHECKS + 1))
echo "    ✓ Bindings OK"
echo ""

echo "╔════════════════════════════════════════════════════════════╗"
echo "║  ✅ All $PASSED_CHECKS/$TOTAL_CHECKS pre-commit checks passed!                       ║"
echo "║                                                            ║"
echo "║  Checks completed:                                         ║"
echo "║    • cargo fmt --check                                     ║"
echo "║    • cargo clippy -- -D warnings                           ║"
echo "║    • cargo test --lib                                      ║"
echo "║    • python3 scripts/verify_bindings.py                    ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""
