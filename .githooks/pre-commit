#!/usr/bin/env bash
#
# Pre-commit hook: enforces code quality before commits
# Runs: cargo fmt --check, cargo clippy, cargo test --lib
#

set -e

# Find repository root by looking for .git directory
find_repo_root() {
    local dir="$1"
    while [[ "$dir" != "/" ]]; do
        if [[ -d "$dir/.git" ]]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(find_repo_root "$SCRIPT_DIR")"

if [[ -z "$REPO_ROOT" ]]; then
    echo "Error: Could not find repository root" >&2
    exit 1
fi

CORE_DIR="$REPO_ROOT/core"

# Change to core directory for cargo commands
cd "$CORE_DIR"

echo "Running pre-commit checks..."

# Step 1: Format check
echo "  Checking formatting..."
if ! cargo fmt --check 2>/dev/null; then
    echo ""
    echo "❌ Format check failed. Run 'cargo fmt' to fix formatting."
    exit 1
fi
echo "  ✓ Formatting OK"

# Step 2: Clippy lint check
echo "  Running clippy..."
if ! cargo clippy -- -D warnings 2>&1; then
    echo ""
    echo "❌ Clippy check failed. Fix the warnings above."
    exit 1
fi
echo "  ✓ Clippy OK"

# Step 3: Unit tests (lib only for speed)
echo "  Running unit tests..."
if ! cargo test --lib 2>&1; then
    echo ""
    echo "❌ Tests failed. Fix the failing tests above."
    exit 1
fi
echo "  ✓ Tests OK"

echo ""
echo "✅ All pre-commit checks passed!"
