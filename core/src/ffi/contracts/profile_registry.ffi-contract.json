            "parameters": [
                {
                    "name": "profile_id",
                    "type": "string",
                    "description": "Profile ID",
                    "required": true
                }
            ],
            "returns": {
                "type": "string",
                "description": "JSON result"
            },
            "errors": []
        },
        {
            "name": "find_compatible_profiles",
            "rust_name": "keyrx_profile_registry_find_compatible_profiles",
            "description": "Find compatible profiles.",
            "parameters": [
                {
                    "name": "layout_type",
                    "type": "string",
                    "description": "Layout type",
                    "required": true
                }
            ],
            "returns": {
                "type": "string",
                "description": "JSON result"
            },
            "errors": []
        }
