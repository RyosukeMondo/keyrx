{
    "$schema": "https://keyrx.dev/schemas/ffi-contract-v1.json",
    "version": "1.0.0",
    "domain": "device_registry",
    "description": "Device registry operations",
    "protocol_version": 1,
    "functions": [
        {
            "name": "list_devices",
            "rust_name": "keyrx_device_registry_list_devices",
            "description": "List all registered devices",
            "parameters": [],
            "returns": {
                "type": "string",
                "description": "JSON array of device objects"
            },
            "errors": [],
            "example": {
                "input": {},
                "output": [
                    {
                        "id": "1234:5678:0001",
                        "name": "KeyRx One",
                        "vendor_id": 4660,
                        "product_id": 22136
                    }
                ]
            }
        },
        {
            "name": "set_remap_enabled",
            "rust_name": "keyrx_device_registry_set_remap_enabled",
            "description": "Enable/Disable remapping for a device",
            "parameters": [
                {
                    "name": "device_key",
                    "type": "string",
                    "description": "Device unique key",
                    "required": true
                },
                {
                    "name": "enabled",
                    "type": "i32",
                    "description": "Non-zero to enable remapping, zero to disable",
                    "required": true
                }
            ],
            "returns": {
                "type": "string",
                "description": "JSON result object"
            },
            "errors": [],
            "example": {
                "input": {
                    "device_key": "1234:5678:0001",
                    "enabled": true
                },
                "output": {
                    "status": "ok"
                }
            }
        }
    ],
    "events": []
}
