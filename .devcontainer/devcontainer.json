{
  "name": "KeyRx Development",
  "image": "mcr.microsoft.com/devcontainers/rust:1-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "stable"
    },
    "ghcr.io/eitsupi/devcontainer-features/just:1": {},
    "ghcr.io/aspect-build/silo-dev-infra/flutter:0": {}
  },
  "postCreateCommand": "just setup",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "Dart-Code.flutter",
        "Dart-Code.dart-code"
      ]
    }
  },
  "forwardPorts": [8080]
}
