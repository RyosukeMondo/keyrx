{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Linux",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "linux"
      ],
      "env": {
        "DISPLAY": ":1"
      }
    },
    {
      "name": "Flutter Linux (Debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "linux",
        "--debug"
      ],
      "env": {
        "DISPLAY": ":1"
      }
    }
  ]
}
